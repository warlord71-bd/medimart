# ─── WooCommerce (medimart.com.bd) ───────────────────────────────────────────
NEXT_PUBLIC_WC_URL=https://medimart.com.bd
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://medimart.com.bd
NEXT_PUBLIC_SITE_NAME=MediMart

# ─── SSLCommerz (BD Payment Gateway) ─────────────────────────────────────────
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_pass
SSLCOMMERZ_IS_LIVE=false   # set true in production

# ─── bKash (Mobile Payments) ─────────────────────────────────────────────────
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password

# ─── n8n Automation Webhooks ──────────────────────────────────────────────────
N8N_ORDER_WEBHOOK=https://n8n.medimart.com.bd/webhook/new-order
N8N_PRESCRIPTION_WEBHOOK=https://n8n.medimart.com.bd/webhook/prescription-upload

# ─── SMS (SSL Wireless / Twilio) ─────────────────────────────────────────────
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=MediMart
