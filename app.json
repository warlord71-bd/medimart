{
  "expo": {
    "newArchEnabled": true,
    "name": "MediMart",
    "slug": "medimart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0D9373",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "bd.com.medimart.app"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#0D9373"
      },
      "package": "bd.com.medimart.app"
    },
    "plugins": [
      "expo-asset",
      "expo-image-picker"
    ]
  }
}